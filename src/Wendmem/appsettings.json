  "Llm": {
    "Provider": "ZAi",
    "ZAi": {
      "ApiKey": "",
      "Endpoint": "https://api.z.ai/api/coding/paas/v4/",
      "ChatModel": "glm-5-turbo",
      "LightModel": "glm-5-turbo",
      "DisableThinkingJson": "{\"thinking\":{\"type\":\"disabled\"}}"
    },
    "Ollama": {
      "Endpoint": "http://localhost:11434/v1/",
      "ChatModel": "Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf",
      "LightModel": "Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf",
      "DisableThinkingJson": "{\"think\":false}"
    },
    "LlamaCpp": {
      "ApiKey": "llamacpp",
      "Endpoint": "http://localhost:8080/v1/",
      "ChatModel": "Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf",
      "LightModel": "Qwen3.6-35B-A3B-UD-Q4_K_XL.gguf",
      "DisableThinkingJson": "{\"chat_template_kwargs\":{\"enable_thinking\":false}}"
    }
  },

  "Palace": {
    "HttpPort": "5133",
    "TopicShiftChunkingEnabled": true,
    "TopicShiftThreshold": 0.75,
    "TargetChunkTokens": 800,
    "MinChunkTokens": 80,
    "MaxChunkTokens": 1800,
    "ChunkOverlapSentences": 0,
    "EnableQueryExpansion": false,
    "QueryExpansionVariants": 2,
    "MinRetrievalScore": 0.0,
    "WakeUpMinL2Score": 0.25,
    "WakeUpCharBudget": 3200,
    "DefaultWing": "default",
    "ForceDefaultWing": true
  },

  "Experiences": {
    "TopK": 5,
    "SamplingN": 8,
    "MaxReflectionAttempts": 3,
    "PruneMinRetrievals": 5,
    "PruneUtilityThreshold": 0.5,
    "ValidationMinScore": 0.5,
    "SuccessScoreThreshold": 1.0,
    "DedupSimilarityThreshold": 0.92,
    "EnableSoftComparison": true,
    "UseSimpleFlow": false,
    "EnableLlmRerank": false,
    "EnableLlmRewrite": false
  }
}
